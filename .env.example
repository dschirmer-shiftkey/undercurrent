# Required for the MCP server (src/mcp/)
# Not needed for core SDK usage

# Supabase project URL (e.g. https://your-project.supabase.co)
KOMATIK_SUPABASE_URL=

# Supabase anon key (public, safe for client-side)
KOMATIK_SUPABASE_KEY=

# Komatik user UUID (from komatik_profiles table)
KOMATIK_USER_ID=
