{
  "name": "@komatik/undercurrent",
  "version": "0.3.1",
  "description": "Context engineering and personalization SDK for AI — invisibly transforms vague human messages into structured, context-rich prompts before the model sees them.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.js",
      "default": "./dist/adapters/index.js"
    },
    "./strategies": {
      "types": "./dist/strategies/index.d.ts",
      "import": "./dist/strategies/index.js",
      "require": "./dist/strategies/index.js",
      "default": "./dist/strategies/index.js"
    },
    "./transports": {
      "types": "./dist/transports/index.d.ts",
      "import": "./dist/transports/index.js",
      "require": "./dist/transports/index.js",
      "default": "./dist/transports/index.js"
    },
    "./komatik": {
      "types": "./dist/komatik/index.d.ts",
      "import": "./dist/komatik/index.js",
      "require": "./dist/komatik/index.js",
      "default": "./dist/komatik/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js",
      "require": "./dist/mcp/server.js",
      "default": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "undercurrent-mcp": "dist/mcp/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "start:mcp": "node dist/mcp/index.js",
    "playground": "tsx src/playground/repl.ts",
    "replay": "tsx src/playground/replay.ts"
  },
  "keywords": [
    "ai",
    "context-engineering",
    "prompt-engineering",
    "personalization",
    "intent-classification",
    "context-enrichment",
    "llm",
    "middleware",
    "mcp"
  ],
  "author": "Komatik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dschirmer-shiftkey/undercurrent.git"
  },
  "homepage": "https://github.com/dschirmer-shiftkey/undercurrent#readme",
  "bugs": {
    "url": "https://github.com/dschirmer-shiftkey/undercurrent/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.1.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
